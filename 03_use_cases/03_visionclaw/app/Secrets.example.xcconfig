// Copy this file to Secrets.xcconfig (git-ignored) and fill in real values.
// Secrets.xcconfig is #include?-ed by BuildSettings.xcconfig and overrides the
// defaults there. Do NOT commit Secrets.xcconfig.

// Apple Developer Team ID — required to run on a physical device.
DEVELOPMENT_TEAM = ABCDE12345

// Meta Wearables Developer Center values.
// In Meta AI Developer Mode you can keep META_APP_ID = 0 and leave CLIENT_TOKEN empty.
META_APP_ID = 0
CLIENT_TOKEN =

// OpenClaw gateway reachable from the phone (same LAN / tailnet as your Mac).
// GATEWAY_TOKEN must match gateway.auth.token in ~/.openclaw/openclaw.json.
GATEWAY_HOST = your-mac.local
GATEWAY_PORT = 18789
GATEWAY_TOKEN = paste-your-gateway-token
